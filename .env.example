# Kryptovox — Environment Variables
# Copy to .env and fill in values

# OpenAI (for Whisper API fallback and embeddings)
OPENAI_API_KEY=sk-...

# Anthropic (for Claude extraction and scoring)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Optional: use Whisper API instead of local model
# Set to "api" for OpenAI Whisper API, "local" for local model
WHISPER_MODE=local
WHISPER_MODEL=large-v3
